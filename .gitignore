# LLMOrchestrator .gitignore — round-275 CONST-053 enrichment.
#
# Forbidden-from-version-control classes per constitution submodule
# §11.4.30. A `.gitignore` line alone is insufficient — no file
# matching these patterns may be CURRENTLY TRACKED.

# === 1. Build artefacts ===
/bin/
/build/
/dist/
/out/
target/
*.exe
*.dll
*.so
*.dylib
*.a
*.o
*.class
*.pyc
/orchestrator
cmd/orchestrator/orchestrator

# === 2. Cache files ===
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
.next/
.cache/
.gradle/
.terraform/

# === 3. Temp files ===
*.tmp
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.orig
*.rej

# === 4. Sensitive-data files (CONST-042 + CONST-053) ===
.env
.env.*
*.env
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# === 5. Generated reports / logs ===
*.log
coverage.out
coverage.html
htmlcov/
*.test
reports/demos/
reports/runtime/

# === 6. OS / IDE personal state ===
.idea/
.history/
.vscode/
*.iml
