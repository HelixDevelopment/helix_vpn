# =============================================================
# HelixVPN — remote-host configuration for the containers submodule
# (vasic-digital/containers, §11.4.76). Decoupled from the submodule
# per §11.4.28(B): host facts live here at the consumer layer, the
# submodule reads them as CONTAINERS_REMOTE_* env vars.
#
# Usage (load before invoking containers tooling):
#   set -a; . deploy/remote-hosts.env; set +a
#
# NOTE: hostnames/usernames/key-PATHS are not secrets (no password;
# the private key itself stays at ~/.ssh/id_ed25519, never in-repo).
# =============================================================

CONTAINERS_REMOTE_ENABLED=true
CONTAINERS_REMOTE_SCHEDULER=resource_aware
CONTAINERS_REMOTE_DEFAULT_SSH_USER=milosvasic
CONTAINERS_REMOTE_DEFAULT_SSH_KEY=~/.ssh/id_ed25519
CONTAINERS_REMOTE_DEFAULT_RUNTIME=podman

# --- Host 1: nezha.local (heavy-testing node) ---
# i7 7th-gen, 8 cpus, 62 GiB RAM, NVMe (277 GiB free), Podman 5.7.1 rootless.
CONTAINERS_REMOTE_HOST_1_NAME=nezha
CONTAINERS_REMOTE_HOST_1_ADDRESS=nezha.local
CONTAINERS_REMOTE_HOST_1_PORT=22
CONTAINERS_REMOTE_HOST_1_USER=milosvasic
CONTAINERS_REMOTE_HOST_1_KEY=~/.ssh/id_ed25519
CONTAINERS_REMOTE_HOST_1_RUNTIME=podman
CONTAINERS_REMOTE_HOST_1_LABELS=role=heavy-testing,arch=amd64,ram=64g,storage=nvme
