#!/usr/bin/env bash
# OpenDesign CLI wrapper for Helix VPN
# Invokes the OpenDesign daemon CLI from the project submodule.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OD_ROOT="${SCRIPT_DIR}/../submodules/open-design"
OD_BIN="${OD_ROOT}/apps/daemon/bin/od.mjs"
if [[ ! -f "${OD_BIN}" ]]; then
  echo "OpenDesign CLI not found at ${OD_BIN}" >&2
  echo "Run: git submodule update --init --recursive submodules/open-design" >&2
  exit 1
fi
exec node "${OD_BIN}" "$@"
